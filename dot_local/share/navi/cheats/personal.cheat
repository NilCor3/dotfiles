grl

% kafka, kcat

# List topics on broker
kcat -L -b <host:port>

# Consume topic from beginning
kcat -C -b <host:port> -t <topic> -o beginning

# Consume latest N messages
kcat -C -b <host:port> -t <topic> -o -<n> -e

# Produce message from stdin
echo '{"key":"value"}' | kcat -P -b <host:port> -t <topic>

# Consume with key display
kcat -C -b <host:port> -t <topic> -f '%k: %s\n'

# SASL/PLAIN auth (e.g. Confluent Cloud)
kcat -C -b <host:port> -t <topic> -X security.protocol=SASL_SSL -X sasl.mechanism=PLAIN -X sasl.username=<key> -X sasl.password=<secret>

% kafka, kaskade

# Browse topics interactively
kaskade <host:port>

% shell, fzf

# Fuzzy kill process
fkill

# Fuzzy cd into directory
fcd

# Fuzzy open file in Helix
fhx

# Fuzzy view git log entry (show commit)
fgl

# Fuzzy switch git branch
fbr

# Fuzzy stage files (git add)
fga

% mise, tasks

# Back up AI setup files (AGENTS.md, CLAUDE.md, .claude/, .github/)
mise run ai-lock

# Restore AI setup files from backup into current working directory
mise run ai-apply

# Remove backup and restore current branch files (after PR merge)
mise run ai-unlock
