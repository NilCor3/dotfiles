% git, log

# Show commit log graph  [gl]
gl

# Show commits by author
git log --oneline --author="<author>"

# Show changes in a commit
git show <commit>

# Search commit messages
git log --oneline --grep="<query>"

# Show file history
git log --oneline --follow -- <file>

% git, branches

# List all branches including remote  [gb]
gb -a

# Switch to branch  [gsw]
gsw <branch>

# Create and switch to new branch  [gsw]
gsw -c <branch>

# Delete local branch  [gbd]
gbd <branch>

# Delete remote branch  [gp]
gp origin --delete <branch>

# Rename current branch  [gb]
gb -m <new_name>

% git, staging

# Stage all changes  [gaa]
gaa

# Stage interactively hunk by hunk  [ga]
ga -p

# Unstage a file
git restore --staged <file>

# Discard changes in working directory
git restore <file>

# Show staged diff  [gds]
gds

% git, commits

# Commit with message  [gcm]
gcm "<message>"

# Amend last commit without changing message  [gca]
gca

# Amend last commit message  [gc]
gc --amend -m "<message>"

# Undo last commit keep changes staged  [gc]
gc --soft HEAD~1

# Create fixup commit for a specific commit  [gc]
gc --fixup <commit>


% git, remote

# Push  [gp]
gp

# Push and set upstream  [gp]
gp -u origin <branch>

# Force push safely  [gpf]
gpf

# Pull with rebase  [gpl]
gpl

# Fetch all remotes and prune deleted branches
git fetch --all --prune

% git, stash

# Stash with description  [gst]
gst push -m "<message>"

# List stashes  [gst]
gst list

# Apply specific stash  [gst]
gst apply stash@{<index>}

# Pop latest stash  [gstp]
gstp

# Drop a stash  [gst]
gst drop stash@{<index>}

% git, rebase

# Interactive rebase on last N commits  [grbi]
grbi HEAD~<n>

# Interactive rebase on main  [grbi]
grbi origin/main

# Autosquash fixup commits  [grbi]
grbi --autosquash origin/main

# Abort rebase  [grb]
grb --abort

# Continue rebase after resolving conflicts  [grb]
grb --continue

% git, merge conflicts

# Open conflicted file in Helix via lazygit (press e on conflict file in lazygit)
lg

% git, misc

# Open lazygit  [lg]
lg

# Cherry-pick a commit
git cherry-pick <commit>

# Show who changed a line
git blame <file>

# Clean untracked files dry run
git clean -nd

# Clean untracked files
git clean -fd

# Get a single file from a branch without checking out
git show <branch>:<path/to/file> > <output_file>

# Get all files from a branch into working tree without checking out
git checkout origin/<branch> -- .

# Bring all changes from a branch as a single staged diff (no commits)
git merge --squash origin/<branch>

% go, build & run

# Run current module
go run .

# Build all packages  [gob]
gob

# Build with race detector
go build -race ./...

# Cross-compile for Linux
GOOS=linux GOARCH=amd64 go build -o <output> ./...

% go, testing

# Run all tests verbose  [gota]
gota

# Run all tests in specific package  [gota]
gota ./<package>/...

# Run tests matching name partial or full  [got]
got <name>

# Run tests matching name in specific package  [got]
got <name> ./<package>/...

# Run with race detector
go test -race ./...

# Run with coverage report
go test -cover ./...

# Generate html coverage report
go test -coverprofile=coverage.out ./... && go tool cover -html=coverage.out

# Clear test cache  [gocc]
gocc

% go, modules

# Initialize a new module
go mod init <module>

# Add missing and remove unused modules  [gom]
gom

# Upgrade a dependency
go get <module>@latest

# Upgrade all dependencies
go get -u ./...

% go, tools

# Run linter  [gol]
gol

# Run linter with auto-fix
golangci-lint run --fix

# Generate code  [gog]
gog

# Vet code
go vet ./...

# Debug binary in current package with Delve  [dlvr]
dlvr

# Debug a specific test with Delve  [dlvt]
dlvt <TestName>

% rust, build & run

# Build debug  [cb]
cb

# Build release  [cb]
cb --release

# Run  [cr]
cr

# Run with arguments  [cr]
cr -- <args>

# Run release  [cr]
cr --release

% rust, testing

# Run all tests  [ct]
ct

# Run tests matching name  [ct]
ct <name>

# Run tests with output  [ctv]
ctv

# Run specific test with output  [ctv]
ctv <name> -- --nocapture

# Debug binary with rust-lldb  [rdb]
rdb

# Debug a specific test with rust-lldb  [rdt]
rdt <test_filter>

# Run with all features  [ct]
ct --all-features

% rust, code quality

# Check without building  [cc]
cc

# Run clippy  [ccl]
ccl

# Run clippy auto-fix  [cclf]
cclf

# Format code  [cf]
cf

# Format all  [cfa]
cfa

# Format check only (CI)  [cf]
cf -- --check

% rust, dependencies

# Add a dependency
cargo add <crate>

# Add a dev dependency
cargo add --dev <crate>

# Update all dependencies
cargo update

# Show dependency tree
cargo tree

% rust, misc

# Generate and open docs  [cdoc]
cdoc

# Clean build artifacts
cargo clean

% npm, packages

# Install dependencies
npm install

# Add a dependency
npm install <package>

# Add a dev dependency
npm install --save-dev <package>

# Remove a package
npm uninstall <package>

# Show outdated packages
npm outdated

# Audit for vulnerabilities
npm audit

# Fix audit issues
npm audit fix

% npm, scripts

# Run a script
npm run <script>

# List available scripts
npm run

# Run tests
npm test

# Run build
npm run build

# Run dev server
npm run dev

% chezmoi, daily

# Check what has changed home vs source
chezmoi diff

# Pull home dir changes back into source
chezmoi re-add

# Apply source to home dir
chezmoi apply

# Add a new file to chezmoi
chezmoi add <file>

# Show managed files
chezmoi managed

# Show status of all managed files
chezmoi status

# Edit a managed file in source
chezmoi edit <file>

% chezmoi, git

# Show git log of dotfiles repo
chezmoi git -- log --oneline

# Push dotfiles
chezmoi git -- push

# Pull latest dotfiles from remote
chezmoi update

% chezmoi, secrets & misc

# Force re-run of a run_once script
chezmoi state delete-bucket --bucket=scriptState

# Open source directory
chezmoi cd

% xh, http requests

# GET request
xh <url>

# GET with custom header
xh <url> <Header>:<value>

# POST JSON (string=value, number:=value)
xh POST <url> key=value key2:=123

# POST with Bearer token
xh <url> Authorization:"Bearer <token>"

# Print only response body (pipe-friendly)
xh --print=b <url>

# Download a file
xh --download <url>

# Follow redirects
xh --follow <url>

# Preview request without sending
xh --offline POST <url> key=value

# Persistent session (persists cookies/headers)
xh --session=<name> <url>

# Pipe response through jq
xh --print=b <url> | jq '<filter>'

% eza, files

# Detailed list with icons and git status  [ll]
eza -lah --icons --git

# Tree view N levels deep  [lt]
eza --tree --icons --git -L <levels>

# Sort by modified time newest first
eza -lah --icons --git --sort=modified --reverse

# Show only directories
eza -lah --icons --only-dirs

# Group directories first
eza -lah --icons --group-directories-first

% pgcli, postgres

# Connect to local database
pgcli <database>

# Connect with user and host
pgcli -h <host> -U <user> <database>

# Connect via URL
pgcli postgresql://<user>:<password>@<host>/<database>

# Inside pgcli: describe a table
\d <table>

# Inside pgcli: list all tables
\dt

# Inside pgcli: list databases
\l

# Inside pgcli: save a named query
\ns <name> SELECT * FROM <table> WHERE <condition>

# Inside pgcli: run a named query
\n <name>

# Inside pgcli: export query result to CSV
\copy (SELECT * FROM <table>) TO '<file>.csv' CSV HEADER

% http, mock, prism

# Mock from OpenAPI spec (local file)
prism mock <openapi.yaml>

# Mock from OpenAPI spec (remote URL)
prism mock <https://api.example.com/openapi.yaml>

# Mock with verbose logging
prism mock --verbose <openapi.yaml>

# Proxy to real API + validate requests/responses
prism proxy <openapi.yaml> <https://real-api.example.com>

% go, tools, air, gotestsum, dlv

# Run gotestsum (pretty test output)
gotestsum

# Watch mode - rerun tests on save
gotestsum --watch

# Show individual test names
gotestsum --format testname ./...

# Initialize air config in project
air init

# Start air live reload server
air

# Start delve debugger on current package
dlv debug

# Attach delve to running process
dlv attach <pid>

# Start delve DAP server (for editor integration)
dlv dap --listen=:2345

# Debug with gdlv GUI + dlv CLI companion (both connected to same session)
dlvg <subcommand> <package>

# Start headless dlv server for multi-client (CLI + gdlv)
dlv <subcommand> --headless --listen=:2345 --accept-multiclient <package>

# Connect gdlv GUI to headless dlv server
gdlv connect :2345

# Connect dlv CLI to headless dlv server
dlv connect :2345

% rust, cargo, bacon, nextest, audit, expand

# Start bacon (background test/check watcher)
bacon

# bacon check mode (no test run)
bacon check

# bacon clippy mode
bacon clippy

# Run tests with nextest
cargo nextest run

# Run a specific test with nextest
cargo nextest run <test_name>

# Audit dependencies for vulnerabilities
cargo audit

# Fix vulnerable dependencies automatically
cargo audit fix

# Expand macros for a module
cargo expand <module>

# Expand the whole crate
cargo expand

% json, jq, fx, jnv

# Interactive JSON explorer (pipe)
<command> | fx

# Open JSON file in fx
fx <file.json>

# fx: JS expression filter
fx <file.json> '.<field>'

# Interactive jq filter builder (pipe)
<command> | jnv

# Open JSON file in jnv
jnv <file.json>

# jq: pretty print
jq . <file.json>

# jq: extract field
jq '.<field>' <file.json>

# jq: filter array
jq '.[] | select(.<field> == "<value>")' <file.json>

# jq: extract keys
jq 'keys' <file.json>

# jq: map over array
jq '[.[] | {name: .<name_field>, id: .<id_field>}]' <file.json>

# jq: compact output (no pretty print)
jq -c '.' <file.json>

# jq: raw string output (no quotes)
jq -r '.<field>' <file.json>

# jq: count array elements
jq 'length' <file.json>

# jq: sort by field
jq 'sort_by(.<field>)' <file.json>

# jq: group by field
jq 'group_by(.<field>)' <file.json>

# Pipe xh response into jnv for exploration
xh <url> | jnv

# Pipe xh response into fx for scripting
xh <url> | fx '.<field>'

% notes, markdown, glow, marksman

# Open notes folder in Helix
n

# Open today's journal entry
n journal

# New meeting note
n meet <title>

# New issue note
n issue <NOV-123>

# New note at path (relative to ~/notes)
n new <work/my-note.md>

# Open scratch.md (quick capture)
n search

# Ripgrep search → fzf file picker with match preview
n grep <pattern>

# Live interactive content search (type to filter, opens hx at exact line)
n search

# Browse notes with glow TUI
ngl

# Fuzzy find notes by filename
n find <query>

# Filter notes by frontmatter type (meeting, issue, daily, ref, system)
n find --type <type>

# Filter notes by tag
n tag <tag>

# Render a single markdown file
glow <file.md>

# Sync notes to git remote (commit + push)
n sync

# Lint markdown file for style issues
rumdl <file.md>

# Lint all markdown files in directory
rumdl <directory>

% typescript, biome, tsx, knip

# Format and lint fix
biome check --apply

# Format only
biome format --write <path>

# Lint check (no fix)
biome check <path>

# Run TypeScript file directly
tsx <file.ts>

# Find unused exports, deps, files
knip

% slides, presentations

# Start a slideshow from markdown
slides <presentation.md>


% helix, build

# Update Helix to latest upstream (fetch, rebase, build, deploy)
cd ~/hx/source && git fetch upstream && git rebase upstream/master && cargo build --release && cd ~/hx && bash setup_build.sh

# Build and deploy Helix (after code change)
cd ~/hx/source && cargo build --release && cd ~/hx && bash setup_build.sh

# Authenticate Copilot in Helix (first time or after token expiry)
python3 ~/hx/copilot_auth.py


% helix, files

# Open yazi file manager in popup at current buffer's dir, open chosen files
# keybind: Space , y

# Open built-in file explorer sidebar
# keybind: Ctrl+e


% helix, testing

# Run test at cursor (Go or Rust)
# keybind: Space , t

# Run whole test function at cursor (Go or Rust)
# keybind: Space , T

# Run all tests in current file (Go or Rust)
# keybind: Space , F


% wezterm, scroll, keybindings

# Scroll view down 1 line
# Keybind: CTRL+SHIFT+j

# Scroll view up 1 line
# Keybind: CTRL+SHIFT+k

# Scroll half page down
# Keybind: CTRL+SHIFT+d

# Scroll half page up
# Keybind: CTRL+SHIFT+u

% tmux, keybindings

# Leader key: Ctrl+Space

# New window
# Keybind: Ctrl+Space n

# Next / prev window
# Keybind: Ctrl+Space ] / [

# Select window by number
# Keybind: Ctrl+Space 1-8

# Rename window
# Keybind: Ctrl+Space R

# Split horizontal (new pane below)
# Keybind: Ctrl+Space s

# Split vertical (new pane right)
# Keybind: Ctrl+Space v

# Navigate panes (h/j/k/l)
# Keybind: Ctrl+Space h/j/k/l

# Zoom pane (toggle fullscreen)
# Keybind: Ctrl+Space z

# Kill pane (with confirm)
# Keybind: Ctrl+Space q

# Kill window (with confirm)
# Keybind: Ctrl+Space x

# Floating shell popup
# Keybind: Ctrl+Space F

# Session picker
# Keybind: Ctrl+Space p

# Session tree chooser
# Keybind: Ctrl+Space W

# Detach session
# Keybind: Ctrl+Space d

# lazygit popup
# Keybind: Ctrl+Space g

# pgcli popup
# Keybind: Ctrl+Space Q

# AI commit popup
# Keybind: Ctrl+Space G

# Move pane mode (swap with h/j/k/l, Esc to exit)
# Keybind: Ctrl+Space M

# Mark pane (for join operations)
# Keybind: Ctrl+Space m

# Show keybinding help
# Keybind: Ctrl+Space ?

% todos, notes

# Add todo to inbox
t add <text>

# Add todo to inbox (open inbox in helix)
t add

# Insert todo checkbox below cursor in Helix (markdown files only)
# keybind: Alt+t in normal mode

# List all open todos (fzf, opens in helix)
t list

# Mark a todo as done (fzf picker)
t done

# Open a todo project file (fzf)
t p

# Open a specific todo project file
t p <project>

# Filter todos by tag (fzf, opens in helix)
t list --tag <tag>

% httpyac, http

# Pick env file and environment for httpyac session
henv

# Run HTTP file with httpyac interactive picker (fzf file select if no arg)
hrun

# Run specific HTTP request by name (uses current HTTPYAC_ENV if set)
httpyac send <file> --name <request_name> --env <env>

# Run all requests in a file
httpyac send <file> --all --env <env>

% amethyst, window

# Focus screen 1 / 2 / 3
# ⌥⇧ W / E / R

# Throw window to screen 1 / 2 / 3
# ⌃⌥⇧ W / E / R

# Throw window to Space N (1-9)
# ⌃⌥⇧ [number]

# Throw window to adjacent Space
# ⌃⌥⇧ ← / →

# Focus prev / next window
# ⌥⇧ J / K

# Swap window with main pane
# ⌥⇧ Enter

# Shrink / expand main pane
# ⌥⇧ H / L

# Cycle layout forward / backward
# ⌥⇧ Space / ⌃⌥⇧ Space

# Toggle float for focused window
# ⌥⇧ T

# Force re-evaluate window layout
# ⌥⇧ Z

% plists, backup

# Backup all tracked app plists (Ice, AltTab, HyperKey) → chezmoi re-add
~/.config/backups/plists/backup-plists.sh && chezmoi re-add ~/.config/backups/plists/

# Restore all tracked app plists (fresh install)
~/.config/backups/plists/restore-plists.sh

% macos, caffeinate

# Prevent idle sleep indefinitely (Ctrl-C to stop)
caffeinate

# Keep display on indefinitely (Ctrl-C to stop)
caffeinate -d

# Prevent idle sleep for N seconds
caffeinate -t <seconds>

# Prevent sleep while a command runs
caffeinate -i <command>

# Prevent sleep until a process exits
caffeinate -w <pid>

% postgres, lsp

# Check SQL file for errors (no DB required)
postgres-language-server check <file>

# Check all SQL files in a directory
postgres-language-server check <directory>

# Init per-project config (creates postgres-language-server.jsonc)
postgres-language-server init

# Open pgcli (postgres interactive client) — tmux: prefix + Q
pgcli

# Connect to postgres with a URL
pgcli <connection_url>

# Connect with explicit host/user/db
pgcli -h <host> -U <user> -d <database>

% files, sd

# Replace text in a file
sd '<old_text>' '<new_text>' <file>

# Replace text across multiple files (glob)
sd '<old_text>' '<new_text>' **/<glob>

# Preview replacements without applying
sd --preview '<old_text>' '<new_text>' <file>

# Replace with regex
sd '<regex>' '<replacement>' <file>

# Replace in all files from fd output
fd -e <ext> | xargs sd '<old_text>' '<new_text>'

% files, massren

# Bulk rename files matching a pattern in current dir
massren *.<ext>

# Bulk rename from fd output
massren $(fd -e <ext>)

# Bulk rename all files in current dir
massren *

% git, forgit

# Interactive stage (fzf hunk selector)   [ga]
ga

# Interactive diff viewer   [gd]
gd

# Interactive log browser   [glo]
glo

# Checkout branch interactively   [gcb]
gcb

# Checkout file interactively   [gcf]
gcf

# Checkout commit interactively   [gco]
gco

# Switch branch interactively   [gsw]
gsw

# Delete branch interactively   [gbd]
gbd

# Interactive stash viewer   [gss]
gss

# Cherry-pick interactively   [gcp]
gcp

# Interactive rebase   [grb]
grb

# Blame interactively   [gbl]
gbl

