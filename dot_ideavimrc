""" Common settings
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
set showmode
set showcmd
set scrolloff=10
set incsearch
set ignorecase
set smartcase
set hlsearch
set number
set relativenumber
set clipboard+=unnamed

""" Idea specific settings
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
set ideajoin
set ideastatusicon=gray

" Key mappings
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Choose autocomplete item with Ctrl+y (both normal and insert mode)
imap <C-y> <Action>(EditorChooseLookupItem)<Action>(InsertInlineCompletionAction)<Action>(EditorChooseLookupItemReplace)

" Save file with Ctrl+s (both normal and insert mode)
map <C-s> <Action>(SaveAll)
imap <C-s> <Action>(SaveAll)

" File navigation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>fF <action>(GotoFile)
map <Leader>ff <action>(com.mituuz.fuzzier.search.Fuzzier)
map <leader>fr <action>(RecentFiles)
map <leader><leader> <Action>(RecentFiles)
map <leader>fl <action>(RecentLocations)
map <leader>fs <action>(NewScratchFile)
map <Leader>fv <action>(com.mituuz.fuzzier.search.FuzzierVCS)

" File manipulation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Move file to another directory
map <Leader>mf <action>(com.mituuz.fuzzier.operation.FuzzyMover)

" Search
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>ss <action>(SearchEverywhere)
map <leader>sf <action>(FindInPath)
map <Leader>sg <action>(com.mituuz.fuzzier.grep.FuzzyGrep)

" Tab navigation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
nnoremap <A-n> :tabnext<CR>
nnoremap <A-p> :tabprev<CR>\

" Pane navigation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l
nnoremap <C-k> <C-w>k
nnoremap <C-j> <C-w>j

" Jump between methods
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map [[ <Action>(MethodUp)
map ]] <Action>(MethodDown)

" Easy visual indentation
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Stay in visual mode when indenting
vnoremap < <gv
" Stay in visual mode when indenting
vnoremap > >gv

" Jump around with easymotion
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>j <Plug>(easymotion-s)

" Open NERDTree (use q to exit)
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>x :NERDTreeToggle<CR>

" Folding
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>zc :action CollapseAllRegions<CR>
map <leader>zo :action ExpandAllRegions<CR>

" Window operations
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>wv <Action>(SplitVertically)
map <leader>ws <Action>(SplitHorizontally)
map <leader>wu <Action>(Unsplit)
map <leader>wm <Action>(MoveEditorToOppositeTabGroup)
map <leader>wf <Action>(HideAllWindows)
" Open terminal
map <leader>wt <Action>(ActivateTerminalToolWindow)

" Code Actions
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Open the context menu with available code actions
map <leader>ca <action>(ShowIntentionActions)
" Format current file
map <Leader>cf <action>(ReformatCode)
" Optimize imports in current file
map <Leader>co <action>(OptimizeImports)
" Comment line
map <leader>cl <action>(CommentByLineComment)
" Comment block
map <leader>cb <action>(CommentByBlockComment)

" Refactoring
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <leader>rn <Action>(RenameElement)
map <leader>rm <Action>(ExtractMethod)
map <leader>rv <Action>(IntroduceVariable)
map <leader>rf <Action>(IntroduceField)
map <leader>rs <Action>(ChangeSignature)
map <leader>rr <Action>(Refactorings.QuickListPopupAction)

" Go to code
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
nmap <leader>gd <Action>(GotoDeclaration)
nmap <leader>gy <Action>(GotoTypeDeclaration)
nmap <leader>gi <Action>(GotoImplementation)
nmap <leader>gs <Action>(GotoSymbol)
nmap <leader>gu <Action>(ShowUsages)
nmap <leader>gr <Action>(ShowUsages)
nmap <leader>gt <Action>(GotoTest)
nmap <leader>gf <Action>(Back)
nmap <leader>gb <Action>(Forward)

" Git windows
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Open the commit dialog
map <leader>vc <Action>(CheckinProject)
" Open the version control tool window
map <leader>vs <Action>(ActivateVersionControlToolWindow)
" Open the branches popup
map <leader>vb <Action>(Git.Branches)
" Show info about the object under cursor
map <Leader>vv <action>(Git.ContextMenu)
" Fuzzy search in VCS tracked files
map <Leader>vf <action>(com.mituuz.fuzzier.FuzzierVCS)
" Reverts selected lines
map <Leader>vrl <action>(Vcs.RollbackChangedLines)

" Errors
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Go to next/previous error in the whole solution
map <leader>en <Action>(ReSharperGotoNextErrorInSolution)
map <leader>ep <Action>(ReSharperGotoPrevErrorInSolution)

" Run actions
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Run the current class or test under the cursor
map <Leader>tr <action>(ContextRun)
" Run all tests in a class or the current class
map <Leader>trs gg<action>(RunClass)<C-O>
" Rerun previous job
map <Leader>tre <action>(Run)
" Open the run configuration dialog
map <Leader>tc <action>(ChooseRunConfiguration)
" Stop currently running process(es)
map <Leader>h <action>(Stop)

" Debug
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Debug the current class or test under the cursor
map <Leader>dr <action>(ContextDebug)
" Debug previous job
map <Leader>dre <action>(Debug)
" Add or remove breakpoint
map <Leader>db <action>(ToggleLineBreakpoint)
" Clear every breakpoint in the project
map <Leader>dx <action>(Debugger.RemoveAllBreakpoints)
" Continue running from a breakpoint
map <Leader>i <action>(Resume)
" Open breakpoint dialog (add conditionals etc.)
map <Leader>deb <action>(EditBreakpoint)
" Enable or disable breakpoint without removing it
map <Leader>dt <action>(ToggleBreakpointEnabled)
" Open ee dialog to run code at a breakpoint
map <Leader>dee <action>(EvaluateExpression)
" Continue running until cursor
map <Leader>dc <action>(RunToCursor)

" AI, copilot
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
map <Leader>ac <action>(copilot.chat.show)
map <Leader>ap <action>(copilot.chat.inline)
" Instead of having to deal with auto suggestions, I want to request them manually
map <leader>as <action>(copilot.requestCompletions)
" imap <C-a> <action>(copilot.requestCompletions)
imap <C-a> <action>(CallInlineCompletionAction)

" Other
"""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
nnoremap <esc> :noh<return><esc>
