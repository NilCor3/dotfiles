# Function to find a directory and insert it into the command line
fzf-redraw-prompt() {
  local selected_dir
  selected_dir=$(find . -maxdepth 3 -type d 2> /dev/null | fzf --height 40% --reverse)
  if [[ -n "$selected_dir" ]]; then
    LBUFFER+="$selected_dir"
  fi
  zle reset-prompt
}

