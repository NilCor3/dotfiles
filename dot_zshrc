# --- Notes ---
export NOTES_DIR="$HOME/notes"

n()      { hx "$NOTES_DIR" }
ns()     { hx "$NOTES_DIR/scratch.md" }
ng()     { glow "$NOTES_DIR" }

nj() {
  local file="$NOTES_DIR/journal/$(date +%Y-%m-%d).md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: daily\ndate: %s\n---\n\n# %s\n\n" "$(date +%Y-%m-%d)" "$(date +%Y-%m-%d)" > "$file"
  fi
  hx "$file"
}

nmeet() {
  local title="${1:-meeting}"
  local file="$NOTES_DIR/work/meet-$(date +%Y-%m-%d)-${title// /-}.md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: meeting\ntags: []\ndate: %s\n---\n\n# %s\n\n## Attendees\n\n## Notes\n\n## Actions\n" "$(date +%Y-%m-%d)" "$title" > "$file"
  fi
  hx "$file"
}

nissue() {
  local id="${1:?usage: nissue NOV-123}"
  local file="$NOTES_DIR/work/issue-${id}.md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: issue\ntags: []\ndate: %s\nissue: %s\n---\n\n# %s\n\n## Context\n\n## Notes\n" "$(date +%Y-%m-%d)" "$id" "$id" > "$file"
  fi
  hx "$file"
}

nn() {
  local path="${1:?usage: nn work/my-note.md}"
  local file="$NOTES_DIR/$path"
  mkdir -p "$(dirname "$file")"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: ref\ntags: []\ndate: %s\n---\n\n# %s\n\n" "$(date +%Y-%m-%d)" "$(basename "${path%.md}")" > "$file"
  fi
  hx "$file"
}

nsync() {
  local prev_dir="$PWD"
  cd "$NOTES_DIR" || return 1
  git add -A && git commit -m "sync: $(date '+%Y-%m-%d %H:%M')"
  # post-commit hook auto-pushes
  cd "$prev_dir"
}

nf() {
  local q="${1:-}"
  local file
  file=$(fd --type f --extension md . "$NOTES_DIR" | fzf --query "$q" --preview 'bat --color=always {}')
  [[ -n "$file" ]] && hx "$file"
}

nft() {
  local ftype="${1:?usage: nft meeting|issue|daily|ref|system|scratch}"
  local file
  file=$(rg "^type: $ftype" "$NOTES_DIR" -l | fzf --preview 'bat --color=always {}')
  [[ -n "$file" ]] && hx "$file"
}

ntag() {
  local tag="${1:?usage: ntag blink}"
  local file
  file=$(rg "tags:.*\b${tag}\b" "$NOTES_DIR" -l | fzf --preview 'bat --color=always {}')
  [[ -n "$file" ]] && hx "$file"
}

