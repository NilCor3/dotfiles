# Debug binary with rust-lldb
rdb() {
  cargo build || return 1
  local bin
  bin=$(cargo metadata --no-deps --format-version 1 2>/dev/null \
    | python3 -c "import json,sys; p=json.load(sys.stdin); \
bins=[t['name'] for pkg in p['packages'] for t in pkg['targets'] if 'bin' in t['kind']]; \
print(bins[0] if bins else '')")
  [[ -z "$bin" ]] && echo "rdb: no binary target found" && return 1
  rust-lldb "target/debug/$bin"
}

# Debug a specific test with rust-lldb
# Usage: rdt [test_filter]
rdt() {
  local exe
  exe=$(cargo test --no-run --message-format=json 2>/dev/null \
    | python3 -c "import json,sys
for line in sys.stdin:
    o = json.loads(line)
    if o.get('executable') and o.get('profile', {}).get('test'):
        print(o['executable'])" \
    | tail -1)
  [[ -z "$exe" ]] && echo "rdt: could not build test binary" && return 1
  rust-lldb "$exe" -- "${1:-}"
}

# --- Notes ---
export NOTES_DIR="$HOME/notes"

n()      { hx "$NOTES_DIR" }
ns()     { hx "$NOTES_DIR/scratch.md" }
ngl()    { glow "$NOTES_DIR" }
ng() {
  local query="${1:?usage: ng <pattern>}"
  local file
  file=$(rg "$query" "$NOTES_DIR" -l | fzf --preview "rg --color=always '$query' {}")
  [[ -n "$file" ]] && hx "$file"
}

# Live interactive content search — type to filter, opens hx at matching line
ngs() {
  local result
  result=$(
    rg --color=always --line-number --no-heading . "$NOTES_DIR" 2>/dev/null |
    fzf --disabled --ansi \
        --bind "change:reload:rg --color=always --line-number --no-heading {q} $NOTES_DIR 2>/dev/null || true" \
        --delimiter : \
        --preview 'bat --color=always --highlight-line {2} {1}' \
        --preview-window 'right:60%:+{2}-5'
  )
  [[ -n "$result" ]] && hx "${result%%:*}:$(echo "$result" | cut -d: -f2)"
}

nj() {
  local file="$NOTES_DIR/journal/$(date +%Y-%m-%d).md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: daily\ndate: %s\n---\n\n# %s\n\n" "$(date +%Y-%m-%d)" "$(date +%Y-%m-%d)" > "$file"
  fi
  hx "$file"
}

nmeet() {
  local title="${1:-meeting}"
  local file="$NOTES_DIR/work/meet-$(date +%Y-%m-%d)-${title// /-}.md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: meeting\ntags: []\ndate: %s\n---\n\n# %s\n\n## Attendees\n\n## Notes\n\n## Actions\n" "$(date +%Y-%m-%d)" "$title" > "$file"
  fi
  hx "$file"
}

nissue() {
  local id="${1:?usage: nissue NOV-123}"
  local file="$NOTES_DIR/work/issue-${id}.md"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: issue\ntags: []\ndate: %s\nissue: %s\n---\n\n# %s\n\n## Context\n\n## Notes\n" "$(date +%Y-%m-%d)" "$id" "$id" > "$file"
  fi
  hx "$file"
}

nn() {
  local note_path="${1:?usage: nn work/my-note.md}"
  local file="$NOTES_DIR/$note_path"
  mkdir -p "$(dirname "$file")"
  if [[ ! -f "$file" ]]; then
    printf -- "---\ntype: ref\ntags: []\ndate: %s\n---\n\n# %s\n\n" "$(date +%Y-%m-%d)" "$(basename "${note_path%.md}")" > "$file"
  fi
  hx "$file"
}

nsync() {
  local prev_dir="$PWD"
  cd "$NOTES_DIR" || return 1
  git add -A && git commit -m "sync: $(date '+%Y-%m-%d %H:%M')"
  # post-commit hook auto-pushes
  cd "$prev_dir"
}

# Review current note with local AI — pipe through mods for structure/clarity feedback
nreview() {
  local file="${1:-}"
  if [[ -z "$file" ]]; then
    file=$(fd --type f --extension md . "$NOTES_DIR" | fzf --preview 'bat --color=always {}')
  fi
  [[ -z "$file" ]] && return 1
  cat "$file" | mods -a ollama -m gemma3:4b "Review this markdown note. Check: 1) Is the structure clear? 2) Are there gaps or incomplete sections? 3) Any grammar/clarity issues? Be concise and specific."
}

nf() {
