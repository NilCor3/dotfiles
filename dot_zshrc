# --- dlv + gdlv companion debugger ---
# Usage: dlvg [./pkg or ./...] [-- args]
# Starts a headless dlv server, opens gdlv GUI, connects dlv CLI in current pane
dlvg() {
  local port=2345
  local subcommand="${1:-debug}"
  shift

  dlv "$subcommand" --headless --listen=":$port" --accept-multiclient "$@" &
  local dlv_pid=$!

  # Wait for server to be ready
  sleep 0.8

  # Open gdlv companion (native GUI or Zellij right pane)
  if [ -n "$ZELLIJ" ]; then
    zellij action new-pane --direction right -- gdlv connect ":$port" &
  else
    # Open gdlv GUI in background (native macOS window)
    gdlv connect ":$port" &
  fi

  # Connect dlv CLI in current pane (blocks until session ends)
  dlv connect ":$port"

  # Cleanup
  kill "$dlv_pid" 2>/dev/null
  wait "$dlv_pid" 2>/dev/null
}
