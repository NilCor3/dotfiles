# --- Todo ---
export TODOS_DIR="$NOTES_DIR/todos"

# _todo_resolve_scope — resolve a scope arg to a search directory
# Returns: directory path to search in
_todo_resolve_scope() {
  local scope="$1"
  [[ -z "$scope" ]] && echo "$TODOS_DIR" && return
  # Exact domain match (work, personal, dev)
  [[ -d "$TODOS_DIR/$scope" ]] && echo "$TODOS_DIR/$scope" && return
  # Fuzzy match on project files across all domains
  local match
  match=$(fd --type f --extension md . "$TODOS_DIR" \
    | grep -i "$scope" | head -1)
  if [[ -n "$match" ]]; then
    echo "$(dirname "$match")"
    return
  fi
  echo "$TODOS_DIR/$scope"
}

# ta [project] [text] — add todo to project or inbox
# ta "text"                → inbox.md
# ta billing "Fix thing"   → work/billing.md (fuzzy match)
# ta work "General task"   → work/general.md
ta() {
  if [[ $# -eq 0 ]]; then
    $EDITOR "$TODOS_DIR/inbox.md"
    return
  fi
  if [[ $# -eq 1 ]]; then
    echo "- [ ] $1" >> "$TODOS_DIR/inbox.md"
    echo "Added to inbox: $1"
    return
  fi
  local target="$1"; shift
  local text="$*"
  # Try exact domain/general first
  if [[ -d "$TODOS_DIR/$target" ]]; then
    echo "- [ ] $text" >> "$TODOS_DIR/$target/general.md"
    echo "Added to $target/general: $text"
    return
  fi
  # Fuzzy match project file
  local file
  file=$(fd --type f --extension md . "$TODOS_DIR" \
    | grep -i "$target" | head -1)
  if [[ -n "$file" ]]; then
    echo "- [ ] $text" >> "$file"
    echo "Added to $(echo "$file" | sed "s|$TODOS_DIR/||"): $text"
  else
    echo "No project matching '$target'. Use tn to create one."
    return 1
  fi
}

# tl [scope] — fzf over open todos, optionally scoped
# tl              → all todos
# tl work         → work/ todos only
# tl billing      → fuzzy match project file
tl() {
  local search_dir
  search_dir=$(_todo_resolve_scope "$1")

  local helix_pane=""
  if [[ -n "$TMUX" ]]; then
    local sess win
    sess=$(tmux display-message -p '#{session_name}')
    win=$(tmux display-message -p '#{window_name}')
    [[ "$sess" == "notes" && "$win" == "todos" ]] && helix_pane="notes:todos.1"
  fi

  while true; do
    local result
    result=$(rg --with-filename --line-number --no-heading -e "- \[ ?\]" "$search_dir" \
      | sed "s|${TODOS_DIR}/||" \
      | fzf --prompt="todos${1:+ ($1)} > " \
            --preview="bat --color=always --highlight-line={2} ${TODOS_DIR}/{1}" \
            --delimiter=: \
            --preview-window=right:50%)
    [[ -z "$result" ]] && return
    local file line
    file="${TODOS_DIR}/$(echo "$result" | cut -d: -f1)"
    line=$(echo "$result" | cut -d: -f2)
    if [[ -n "$helix_pane" ]]; then
      tmux send-keys -t "$helix_pane" Escape
      tmux send-keys -t "$helix_pane" ":open ${file}:${line}" Enter
    else
      $EDITOR "+$line" "$file"
      return
    fi
  done
}

# td [scope] — mark a todo as done (fzf picker)
td() {
  local search_dir
  search_dir=$(_todo_resolve_scope "$1")
  local result
  result=$(rg --with-filename --line-number --no-heading -e "- \[ ?\]" "$search_dir" \
    | sed "s|${TODOS_DIR}/||" \
    | fzf --prompt="mark done${1:+ ($1)} > " \
          --preview="bat --color=always --highlight-line={2} ${TODOS_DIR}/{1}" \
          --delimiter=: \
          --preview-window=right:50%)
  [[ -z "$result" ]] && return
  local file line
  file="${TODOS_DIR}/$(echo "$result" | cut -d: -f1)"
  line=$(echo "$result" | cut -d: -f2)
  sed -i '' -E "${line}s/- \[ ?\]/- [x]/" "$file"
  echo "Done: $(sed -n "${line}p" "$file")"
}

# tp [project] — open a project todo file (fzf if no arg)
tp() {
  if [[ -n "$1" ]]; then
    # Fuzzy match project file
    local file
    file=$(fd --type f --extension md . "$TODOS_DIR" \
      | grep -i "$1" | head -1)
    if [[ -n "$file" ]]; then
      $EDITOR "$file"
    else
      echo "No project matching '$1'. Use tn to create one."
      return 1
    fi
  else
    local file
    file=$(fd --type f --extension md . "$TODOS_DIR" \
      | sed "s|$TODOS_DIR/||" \
      | fzf --prompt="project > " --preview="bat --color=always $TODOS_DIR/{}")
    [[ -n "$file" ]] && $EDITOR "$TODOS_DIR/$file"
  fi
}

# tg <pattern> — filter todos by +project, @context, or #tag
# tg @work       → all @work todos
# tg +billing    → all +billing project todos
# tg urgent      → all #urgent tagged todos (legacy behavior)
tg() {
  local pattern="${1:?usage: tg @work | tg +billing | tg urgent}"
  # If no prefix, assume #tag for backward compatibility
  [[ "$pattern" != @* && "$pattern" != +* ]] && pattern="#${pattern}"
  local result
  result=$(rg --with-filename --line-number --no-heading -F "$pattern" "$TODOS_DIR" \
    | sed "s|${TODOS_DIR}/||" \
    | fzf --prompt="${pattern} > " --delimiter=: \
          --preview="bat --color=always --highlight-line={2} ${TODOS_DIR}/{1}" \
          --preview-window=right:50%)
  [[ -z "$result" ]] && return
  local file line
  file="$TODOS_DIR/$(echo "$result" | cut -d: -f1)"
  line=$(echo "$result" | cut -d: -f2)
  $EDITOR "+$line" "$file"
}

# Domain shortcuts
tw()   { tl work; }
tper() { tl personal; }
tdev() { tl dev; }

# tn <domain> <project> [description] — create a new project todo file
# tn work billing "Billing service tasks"
tn() {
  local domain="${1:?usage: tn work|personal|dev <project> [description]}"
  local project="${2:?usage: tn $domain <project> [description]}"
  shift 2
  local desc="${*:-$project todos}"
  local dir="$TODOS_DIR/$domain"
  local file="$dir/${project}.md"
  if [[ ! -d "$dir" ]]; then
    echo "Unknown domain: $domain (expected work, personal, or dev)"
    return 1
  fi
  if [[ -f "$file" ]]; then
    echo "Project already exists: $domain/$project.md"
    $EDITOR "$file"
    return
  fi
  cat > "$file" <<EOF
---
type: todo
project: $project
context: $domain
tags: []
date: $(date +%Y-%m-%d)
---
# $desc

EOF
  echo "Created $domain/$project.md"
  $EDITOR "$file"
}

