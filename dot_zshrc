# --- dlv + gdlv companion debugger ---
# Usage: dlvg [./pkg or ./...] [-- args]
# Starts a headless dlv server, opens gdlv GUI, connects dlv CLI in current pane
dlvg() {
  local port=2345
  local subcommand="${1:-debug}"
  shift

  dlv "$subcommand" --headless --listen=":$port" --accept-multiclient "$@" &
  local dlv_pid=$!

  # Wait for server to be ready
  sleep 0.8

  # Open gdlv GUI in background (native macOS window)
  gdlv connect ":$port" &

  # Connect dlv CLI in current pane (blocks until session ends)
  dlv connect ":$port"

  # Cleanup
  kill "$dlv_pid" 2>/dev/null
  wait "$dlv_pid" 2>/dev/null
}

# --- httpyac: HTTP file runner ---
# henv: pick env file and environment, export HTTPYAC_ENV for the session
henv() {
  local env_file
  env_file=$(fd -t f -g "http-client.env.json" . 2>/dev/null | fzf --prompt="env file> " --height=10) || return 1
  export HTTPYAC_ENV_FILE="$env_file"
  local env_name
  env_name=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); [print(k) for k in d if not k.startswith('$')]" "$env_file" | fzf --prompt="environment> " --height=10) || return 1
  export HTTPYAC_ENV="$env_name"
  echo "httpyac env: $env_name (from $env_file)"
}

# hrun [file]: pick .http file with fzf (if not given), run with httpyac interactive picker
hrun() {
  local file="${1:-}"
  if [[ -z "$file" ]]; then
    file=$(fd -t f -e http -e rest . 2>/dev/null | fzf --prompt="http file> " --height=15) || return 1
  fi
  local args=()
  [[ -n "${HTTPYAC_ENV:-}" ]] && args+=(--env "$HTTPYAC_ENV")
  if grep -qE '^# @name' "$file"; then
    # @name annotation format
    local name
    name=$(grep -E '^# @name' "$file" | sed 's/# @name *//' | fzf --prompt="request> " --height=15) || return 1
    args+=(--name "$name")
  else
    # ### description format (IntelliJ style) — select by line number
    local selection
    selection=$(grep -nE '^### ?' "$file" | sed 's/^//' | fzf --prompt="request> " --height=15 --delimiter=':' --with-nth='2..') || return 1
    local lineno
    lineno=$(echo "$selection" | cut -d: -f1)
    args+=(--line "$lineno")
  fi
  httpyac send "$file" "${args[@]}" 2>/dev/null
}
