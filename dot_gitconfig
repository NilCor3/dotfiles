[include]
	path = /Users/joakim.karlsson/.config/delta/themes.gitconfig
[user]
	name = Joakim Karlsson
	email = joakim.karlsson@fortnox.se

[includeIf "gitdir:~/dev/"]
	path = ~/.config/git/personal.gitconfig
[pull]
	rebase = true
[core]
	excludesfile = ~/.gitignore
	pager = delta
[interactive]
    diffFilter = delta --color-only
[merge]
    conflictStyle = zdiff3
[mergetool]
	prompt = false
	keepBackup = false
[delta]
	navigate = true
	dark = true
	features = gruvmax-fang
	side-by-side = false
