theme = gruvbox-material-soft-dark
font-family = "FiraMono Nerd Font Mono"

keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right

keybind = super+shift+h=resize_split:left,10
keybind = super+shift+j=resize_split:down,10
keybind = super+shift+k=resize_split:up,10
keybind = super+shift+l=resize_split:right,10
