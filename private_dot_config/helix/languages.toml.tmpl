[language-server.postgres-ls]
command = "postgres-language-server"
args = ["lsp-proxy"]
timeout = 10

[language-server.copilot]
command = "copilot-language-server"
args = ["--stdio"]
environment = { "NODE_NO_WARNINGS" = "1" }

[language-server.copilot.config]
editorInfo = { name = "Helix", version = "25.01" }
editorPluginInfo = { name = "helix-copilot", version = "0.1.0" }

[language-server.jdtls]
command = "jdtls"
args = [
  "--jvm-arg=-javaagent:{{ .chezmoi.homeDir }}/.config/helix/lang_servers/lombok.jar",
  "-data", "{{ .chezmoi.homeDir }}/code/workspace/helix-jdtls"
]

[language-server.jdtls.config.settings.java]
format.enabled = true
format.settings.url = "{{ .chezmoi.homeDir }}/.config/helix/lang_servers/java-code-style.xml"
format.settings.profile = "fortnoxStyle"
eclipse.downloadSource = true
maven.downloadSources = true
signatureHelp.enabled = true
contentProvider.preferred = "fernflower"
saveActions.organizeImports = false
configuration.updateBuildConfiguration = "interactive"
referencesCodeLens.enabled = true
inlayHints.parameterNames.enabled = "all"

[language-server.jdtls.config.settings.java.completion]
favoriteStaticMembers = [
  "org.hamcrest.MatcherAssert.assertThat",
  "org.hamcrest.Matchers.*",
  "org.hamcrest.CoreMatchers.*",
  "org.junit.jupiter.api.Assertions.*",
  "java.util.Objects.requireNonNull",
  "java.util.Objects.requireNonNullElse",
  "org.mockito.Mockito.*"
]
filteredTypes = ["com.sun.*", "io.micrometer.shaded.*", "java.awt.*", "jdk.*", "sun.*"]
importOrder = ["java", "jakarta", "javax", "com", "org"]

[language-server.jdtls.config.settings.java.sources.organizeImports]
starThreshold = 9999
staticThreshold = 9999

[language-server.jdtls.config.settings.java.codeGeneration]
toString.template = "${object.className}{${member.name()}=${member.value}, ${otherMembers}}"
hashCodeEquals.useJava7Objects = true
useBlocks = true

[[language]]
name = "java"
roots = ["pom.xml", "build.gradle", "mvnw", "gradlew", ".git"]
language-servers = ["jdtls", { name = "copilot", only-features = ["inline-completion"] }]
auto-format = true

[language-server.rust-analyzer.config]
checkOnSave = true
# Use clippy instead of plain cargo check — catches more issues and non-idiomatic code
check.command = "clippy"
# Run clippy across all feature flag combinations
check.features = "all"
# Make rust-analyzer aware of code behind all #[cfg(feature = "...")] guards
cargo.features = "all"
# Expand procedural macros (#[derive], tokio::main, etc.) so LSP understands generated code
procMacro.enable = true
# Show ref/ref mut hints on pattern bindings
inlayHints.bindingModeHints.enable = true
# Show what each closure captures from the environment and how (move, borrow, etc.)
inlayHints.closureCaptureHints.enable = true
# Show return type hint on block-body closures |x| { ... }, skip one-liners
inlayHints.closureReturnTypeHints.enable = "with_block"
# Show numeric discriminant values on fieldless enum variants (A = 0, B = 1)
inlayHints.discriminantHints.enable = "fieldless"
# Show &* reborrow hints to make implicit reborrows in function calls visible
inlayHints.expressionAdjustmentHints.enable = "reborrow"
# Show elided lifetimes on functions, skip trivially obvious ones
inlayHints.lifetimeElisionHints.enable = "skip_trivial"

[[language]]
name = "rust"
roots = ["Cargo.toml", "Cargo.lock"]
language-servers = [
  "rust-analyzer",
  { name = "copilot", only-features = ["inline-completion"] },
]
# Format with rustfmt using the 2024 edition ruleset on save
formatter = { command = "rustfmt", args = ["--edition", "2024"] }
auto-format = true

[language.debugger]
name = "lldb-dap"
transport = "stdio"
command = "/opt/homebrew/opt/llvm/bin/lldb-dap"

[[language.debugger.templates]]
name = "binary"
request = "launch"
completion = [{ name = "binary", completion = "filename" }]
args = { program = "{0}", initCommands = ["breakpoint set --name main"] }

[[language.debugger.templates]]
name = "cargo"
request = "launch"
completion = [{ name = "target", completion = "directory", default = "." }]
args = { cargo = { args = ["build"] }, program = "{0}/target/debug/{0}", initCommands = ["breakpoint set --name main"] }

[language-server.gopls]
command = "gopls"

[language-server.gopls.config.hints]
# Show inferred type on := assignments, e.g. x := foo() shows x: MyType
assignVariableTypes = true
# Show field names in struct/slice literals that omit them, e.g. Point{1,2} -> Point{x:1, y:2}
compositeLiteralFields = true
# Show resolved values of constants inline
constantValues = true
# Show inferred generic type parameters on function calls
functionTypeParameters = true
# Show parameter names at call sites, e.g. foo(count: 5, verbose: true)
parameterNames = true
# Show types of k, v variables in for k, v := range ... loops
rangeVariableTypes = true

[language-server.gopls.config.analyses]
# Warn on unused function parameters
unusedparams = true
# Warn on unused variables beyond what the compiler catches
unusedvariable = true
# Suggest replacing interface{} with any (Go 1.18+)
useany = true
# Detect nil pointer dereferences the compiler misses
nilness = true

[language-server.gopls.config]
# Use gofumpt rules inside gopls — stricter than gofmt (blank lines, grouping, etc.)
gofumpt = true
# Run staticcheck analyses through gopls (style, correctness, performance)
staticcheck = true

[[language]]
name = "go"
roots = ["go.work", "go.mod"]
language-servers = ["gopls", { name = "copilot", only-features = ["inline-completion"] }]
# Format and auto-manage import blocks on save
formatter = { command = "goimports" }
auto-format = true

[[language]]
# LSP support (hover, diagnostics) in go.mod files
name = "gomod"
language-servers = ["gopls"]

[[language]]
# LSP support (hover, diagnostics) in go.work files
name = "gowork"
language-servers = ["gopls"]

[[language]]
name = "sql"
language-servers = ["postgres-ls", { name = "copilot", only-features = ["inline-completion"] }]
auto-format = true
roots = ["postgres-language-server.jsonc", ".git"]
file-types = ["sql"]

[language.indent]
tab-width = 2
unit = "  "

[[language]]
name = "markdown"
# Wrap lines at 80 chars and auto-fix on save via prettier
text-width = 80
formatter = { command = "prettier", args = ["--parser", "markdown", "--prose-wrap", "always", "--print-width", "80"] }
auto-format = true
